# DigitalOcean Worker — environment variables
# Copy this file to .env for local testing (never commit .env)

# Required: the public URL of your deployed Replit app (no trailing slash)
REPLIT_APP_URL=https://your-app-name.replit.app

# Required: shared secret — must match SYNC_TOKEN set in Replit Secrets
# Generate a token: python -c "import secrets; print(secrets.token_hex(32))"
SYNC_TOKEN=replace_with_a_strong_random_token

# Optional: label shown in the dashboard "DO Worker" badge
WORKER_VERSION=1.0.0

# Optional: seconds between status polls while a sync is running (default 60)
POLL_INTERVAL=60

# Optional: hours before the poll loop gives up waiting for a sync (default 3)
SYNC_TIMEOUT_H=3
